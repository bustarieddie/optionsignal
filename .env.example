APP_NAME="OptionSignal Pro"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
# Display/processing timezone (e.g. Asia/Kuala_Lumpur, America/New_York, UTC).
APP_TIMEZONE=Asia/Kuala_Lumpur

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# Keep at 1 on Windows — the PHP built-in server's multi-worker mode fails to bind there.
PHP_CLI_SERVER_WORKERS=1

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# DATABASE
# Dev default: SQLite (zero-install). For production switch to MySQL/Postgres.
# ---------------------------------------------------------------------------
DB_CONNECTION=sqlite
# --- Production (MySQL) ---
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=optionsignal
# DB_USERNAME=root
# DB_PASSWORD=
# --- Production (PostgreSQL) ---
# DB_CONNECTION=pgsql
# DB_PORT=5432

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ---------------------------------------------------------------------------
# QUEUE / CACHE / BROADCAST
# Dev default: database driver (no Redis needed). The queue worker MUST run:
#   php artisan queue:work
# Production: switch QUEUE_CONNECTION + CACHE_STORE to redis.
# ---------------------------------------------------------------------------
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database
# CACHE_PREFIX=

# Dev: BROADCAST_CONNECTION=reverb (single-node, no Redis). Falls back gracefully
# to log if Reverb isn't running (signals still persist, no live push).
BROADCAST_CONNECTION=reverb

# --- Production Redis ---
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
MEMCACHED_HOST=127.0.0.1

# ---------------------------------------------------------------------------
# LARAVEL REVERB (WebSocket)  —  run with:  php artisan reverb:start
# ---------------------------------------------------------------------------
REVERB_APP_ID=optionsignal
REVERB_APP_KEY=local-reverb-key
REVERB_APP_SECRET=local-reverb-secret
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http
# Production: set REVERB_HOST to your domain and REVERB_SCHEME=https (TLS terminated by proxy).

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ---------------------------------------------------------------------------
# MAIL  —  dev logs to storage/logs/laravel.log (read verification links there)
# ---------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="alerts@optionsignal.local"
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# OPTIONSIGNAL PRO  —  app-specific
# ---------------------------------------------------------------------------
# Shared secret that TradingView must send inside the webhook JSON body.
TRADINGVIEW_WEBHOOK_SECRET=change-me-to-a-long-random-string

# Optional Telegram notification channel (leave blank to disable).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Real-time quote feed. provider: auto|finnhub|yahoo|null.
# "auto" uses Finnhub when FINNHUB_API_KEY is set, else keyless Yahoo.
QUOTE_FEED_ENABLED=true
QUOTE_PROVIDER=auto
QUOTE_POLL_SECONDS=15
# Free real-time US quotes — get a key at https://finnhub.io (free tier).
FINNHUB_API_KEY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
